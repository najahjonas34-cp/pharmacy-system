# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:3001

# Logging
LOG_LEVEL=debug

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads
